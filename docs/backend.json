
{
  "entities": {
    "PlayerProfile": {
      "title": "PlayerProfile",
      "type": "object",
      "description": "Represents a player's profile.",
      "properties": {
        "id": { "type": "string" },
        "nickname": { "type": "string" },
        "avatar": { "type": "string" },
        "score": { "type": "number" }
      },
      "required": ["id", "nickname", "avatar"]
    },
    "GameSession": {
      "title": "GameSession",
      "type": "object",
      "description": "Represents an ongoing game session.",
      "properties": {
        "id": { "type": "string" },
        "hostPlayerId": { "type": "string" },
        "status": { "type": "string" },
        "currentLetter": { "type": "string" },
        "roundCount": { "type": "number" },
        "members": { "type": "object" },
        "validationMode": { "type": "string" }
      }
    },
    "SessionPlayer": {
      "title": "SessionPlayer",
      "type": "object",
      "description": "A player within a specific session.",
      "properties": {
        "id": { "type": "string" },
        "nickname": { "type": "string" },
        "avatar": { "type": "string" },
        "score": { "type": "number" },
        "isHost": { "type": "boolean" },
        "lastRoundScore": { "type": "number" }
      }
    },
    "Submission": {
      "title": "Submission",
      "type": "object",
      "description": "A player's round answers.",
      "properties": {
        "id": { "type": "string" },
        "playerId": { "type": "string" },
        "answers": { "type": "object" },
        "roundCount": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/player_profiles/{playerId}": {
      "schema": "#/entities/PlayerProfile",
      "description": "Individual player profiles."
    },
    "/game_sessions/{gameSessionId}": {
      "schema": "#/entities/GameSession",
      "description": "Active game sessions."
    },
    "/game_sessions/{gameSessionId}/players/{playerId}": {
      "schema": "#/entities/SessionPlayer",
      "description": "Players currently in the session."
    },
    "/game_sessions/{gameSessionId}/submissions/{playerId}": {
      "schema": "#/entities/Submission",
      "description": "Round submissions for a session."
    }
  }
}
