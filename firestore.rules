
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy:
     * This ruleset implements a hybrid security model designed for a multiplayer game environment.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHost(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    function getSession(gameSessionId) {
      return get(/databases/$(database)/documents/game_sessions/$(gameSessionId)).data;
    }

    function isSessionMember(gameSessionId) {
      // Use parent document lookup to verify membership via map key existence
      let session = get(/databases/$(database)/documents/game_sessions/$(gameSessionId)).data;
      return isSignedIn() && session.members[request.auth.uid] == true;
    }

    // --- Collection Rules ---

    match /player_profiles/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(playerId);
      allow update: if isOwner(playerId);
      allow delete: if isOwner(playerId);
    }

    match /game_sessions/{gameSessionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostPlayerId == request.auth.uid;
      allow update: if isHost(resource.data.hostPlayerId) || isSignedIn();
      allow delete: if isHost(resource.data.hostPlayerId);

      // Submissions secured by parent session membership
      match /submissions/{playerId} {
        // Explicitly allow list/get if the user is part of the session
        allow get, list: if isSessionMember(gameSessionId);
        allow create, update: if isOwner(playerId);
        allow delete: if isOwner(playerId) || isHost(getSession(gameSessionId).hostPlayerId);
      }
    }
  }
}
