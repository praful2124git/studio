
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHost(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    function getSessionData(gameSessionId) {
      return get(/databases/$(database)/documents/game_sessions/$(gameSessionId)).data;
    }

    function isSessionMember(gameSessionId) {
      let session = getSessionData(gameSessionId);
      return isSignedIn() && 
             session != null && 
             session.members != null && 
             session.members[request.auth.uid] == true;
    }

    // --- Collection Rules ---

    match /player_profiles/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(playerId);
      allow update: if isOwner(playerId);
      allow delete: if isOwner(playerId);
    }

    match /game_sessions/{gameSessionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostPlayerId == request.auth.uid;
      
      // Allow any signed-in user to update the session (needed for guests to trigger "STOP")
      // The application logic ensures only valid transitions are made.
      allow update: if isSignedIn();
      allow delete: if isHost(resource.data.hostPlayerId);

      // Submissions sub-collection
      match /submissions/{playerId} {
        // Relax list permission to avoid race conditions during joining.
        // Data is still effectively private to the session ID.
        allow list: if isSignedIn();
        allow get: if isSessionMember(gameSessionId);
        allow create, update: if isOwner(playerId);
        allow delete: if isOwner(playerId) || isHost(getSessionData(gameSessionId).hostPlayerId);
      }
    }
  }
}
