
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy:
     * This ruleset implements a hybrid security model designed for a multiplayer game environment.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isHost(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    function isMember(membersMap) {
      return isSignedIn() && membersMap.keys().hasAny([request.auth.uid]);
    }

    // --- Collection Rules ---

    match /player_profiles/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(playerId);
      allow update: if isOwner(playerId);
      allow delete: if isOwner(playerId);
    }

    match /game_sessions/{gameSessionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostPlayerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.hostPlayerId) || isSignedIn();
      allow delete: if isExistingOwner(resource.data.hostPlayerId);

      // Rule for submissions subcollection
      match /submissions/{playerId} {
        allow get, list: if isMember(resource.data.members);
        allow create, update: if isOwner(playerId) && isMember(request.resource.data.members);
        allow delete: if isOwner(playerId) || isHost(resource.data.hostPlayerId);
      }
    }
  }
}
