
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helper Functions
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getSessionData(gameSessionId) {
      return get(/databases/$(database)/documents/game_sessions/$(gameSessionId)).data;
    }

    function isSessionMember(gameSessionId) {
      let session = getSessionData(gameSessionId);
      return isSignedIn() && 
             session != null && 
             session.members != null && 
             session.members[request.auth.uid] == true;
    }

    function isHost(gameSessionId) {
      let session = getSessionData(gameSessionId);
      return isSignedIn() && session.hostPlayerId == request.auth.uid;
    }

    // --- Collection Rules ---

    match /player_profiles/{playerId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(playerId);
      allow delete: if isOwner(playerId);
    }

    match /game_sessions/{gameSessionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostPlayerId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isHost(gameSessionId);

      match /players/{playerId} {
        allow get, list: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if isOwner(playerId) || isHost(gameSessionId);
      }

      match /submissions/{playerId} {
        allow list: if isSignedIn();
        allow get: if isSessionMember(gameSessionId);
        allow create, update: if isOwner(playerId);
        allow delete: if isOwner(playerId) || isHost(gameSessionId);
      }
    }
  }
}
